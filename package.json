{
  "name": "localshare",
  "version": "1.0.0",
  "author": "CreativeUtil",
  "description": "Share files between devices on the same network",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server-only": "node server.js",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.localshare.app",
    "productName": "LocalShare",
    "copyright": "Copyright © 2026 CreativeUtil",
    "directories": { "output": "dist" },
    "files": ["**/*", "!dist/**", "!*.log"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LocalShare"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "public/logo.png",
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "serve-favicon": "^2.5.1",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.1"
  }
}
